{
  "name": "biteworthy",
  "private": true,
  "version": "0.0.0",
  "description": "Scan any menu, see only what you can eat.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "api": "pnpm --filter @biteworthy/api",
    "web": "pnpm --filter @biteworthy/web",
    "mobile": "pnpm --filter @biteworthy/mobile"
  },
  "devDependencies": {
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.1",
      "@types/react-dom": "^19.0.2"
    }
  }
}
