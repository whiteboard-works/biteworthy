# Phase 5.1.1 — Kamal secrets template.
#
# Copy to `.kamal/secrets` (gitignored) and fill in real values
# before `kamal env push`. Kamal sources this file as a bash script,
# so values are plain `KEY=value` lines.
#
# Where each value comes from:
#
#   KAMAL_REGISTRY_PASSWORD
#     GitHub → Settings → Developer settings → Personal access tokens
#     (classic) → "Generate new token" with `write:packages` +
#     `read:packages` scopes. Lets Kamal push the built image to
#     ghcr.io/whiteboard-works/biteworthy-api.
#
#   RAILS_MASTER_KEY
#     `cat config/master.key` (gitignored). Required for Rails to
#     decrypt config/credentials.yml.enc in production.
#
#   DATABASE_URL
#     Neon → biteworthy-prod project → Connection details → POOLED
#     URL (the unpooled one will exhaust connections under
#     puma+worker concurrency).
#
#   DEVISE_JWT_SECRET_KEY
#     `bin/rails secret` (64+ random chars). Production must set this
#     so rotating Rails.application.secret_key_base doesn't
#     invalidate every issued JWT.
#
#   ANTHROPIC_API_KEY
#     console.anthropic.com — same key as Phase 2.1+ uses.
#
#   ADMIN_USERNAME / ADMIN_PASSWORD
#     Avo /admin HTTP basic-auth gate. Pick something not "admin".
#
#   SMTP_USERNAME / SMTP_PASSWORD
#     Postmark → Servers → BiteWorthy → API tokens. Same Server API
#     token in BOTH fields (Postmark's auth pattern).
#
#   R2_*
#     Cloudflare → R2 → biteworthy-blobs bucket → Manage API tokens.
#     R2_ENDPOINT looks like https://<account-id>.r2.cloudflarestorage.com.
#
#   *_OAUTH_*
#     Google Cloud Console / Apple Developer (Phase 1.2). Same values
#     as the local .env if you have them; not required to deploy
#     unless OAuth login is being tested in prod.

KAMAL_REGISTRY_PASSWORD=ghp_REPLACE_ME
RAILS_MASTER_KEY=REPLACE_ME
DATABASE_URL=postgresql://USER:PASS@ep-xxxx.us-east-1.aws.neon.tech/biteworthy?sslmode=require
DEVISE_JWT_SECRET_KEY=REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ADMIN_USERNAME=REPLACE_ME
ADMIN_PASSWORD=REPLACE_ME
SMTP_USERNAME=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=biteworthy-blobs
R2_ENDPOINT=https://REPLACE_ME.r2.cloudflarestorage.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
