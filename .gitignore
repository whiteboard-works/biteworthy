# Monorepo root .gitignore
# Per-app rules live in apps/<name>/.gitignore.

# Node / pnpm / turbo
node_modules/
.pnpm-store/
.turbo/
.next/
.expo/
.vercel/
dist/
build/
out/

# Ruby / Rails (apps/api/)
**/tmp/
**/log/
**/storage/
**/.bundle/
**/vendor/bundle/
**/coverage/
**/public/assets/
**/public/packs/
**/public/system/
*.rbc
.byebug_history

# Env / secrets
.env
.env.local
.env.*.local
**/config/master.key
**/config/credentials/*.key
**/config/application.yml

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo

# Logs / debug
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
report.*.json

# TypeScript
*.tsbuildinfo

# Mobile
**/ios/Pods/
**/ios/build/
**/android/.gradle/
**/android/build/
**/android/app/build/
*.keystore
!debug.keystore
